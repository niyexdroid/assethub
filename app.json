{
  "expo": {
    "name": "AssetHub",
    "slug": "niyexdroid-asset-hub",
    "version": "1.0.0",
    "newArchEnabled": true,
    "plugins": [
      "expo-asset",
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#12A376"
        }
      ]
    ],
    "android": {
      "package": "com.niyexdroid.assethub",
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true
    },
    "ios": {
      "bundleIdentifier": "com.niyexdroid.assethub"
    }
  }
}
