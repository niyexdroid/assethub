{
  "expo": {
    "name": "AssetHub",
    "slug": "niyexdroid-asset-hub",
    "version": "1.0.0",
    "scheme": "assethub",
    "newArchEnabled": true,
    "plugins": [
      "expo-asset",
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.426756347604-bcu0v0pb5n53gv1s61l5h10g2ic6sqj4"
        }
      ]
    ],
    "android": {
      "package": "com.niyexdroid.assethub",
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true
    },
    "ios": {
      "bundleIdentifier": "com.niyexdroid.assethub"
    }
  }
}
