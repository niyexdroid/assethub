{
  "name": "niyexdroid-prop-man-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "docker-compose up -d && expo start --port 8081",
    "dev:rebuild": "docker-compose up -d && expo run:android --port 8081 --device",
    "dev:rebuild:clean": "docker-compose up -d && expo run:android --port 8081 --device --no-build-cache",
    "dev:emulator": "docker-compose up -d && expo run:android --port 8081",
    "start": "expo start --port 8081",
    "android": "expo run:android --port 8081",
    "ios": "expo run:ios",
    "adb:reverse": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:4000 tcp:4000",
    "adb:device": "adb -d reverse tcp:8081 tcp:8081 && adb -d reverse tcp:4000 tcp:4000",
    "adb:emulator": "adb -e reverse tcp:8081 tcp:8081 && adb -e reverse tcp:4000 tcp:4000",
    "backend": "docker-compose up -d",
    "backend:rebuild": "docker-compose up --build -d",
    "backend:logs": "docker-compose logs -f api",
    "backend:down": "docker-compose down"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.2.3",
    "@gorhom/bottom-sheet": "^5.0.0",
    "@hookform/resolvers": "^3.3.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.17.9",
    "axios": "^1.6.2",
    "expo": "~55.0.13",
    "expo-asset": "~55.0.12",
    "expo-blur": "~55.0.14",
    "expo-document-picker": "~55.0.13",
    "expo-image-picker": "~55.0.18",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.12",
    "expo-location": "~55.1.8",
    "expo-notifications": "~55.0.18",
    "expo-router": "~55.0.11",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.17",
    "expo-status-bar": "~55.0.5",
    "lottie-react-native": "~7.3.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.49.2",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-charts": "^1.4.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-skeleton-placeholder": "^5.2.4",
    "react-native-svg": "15.15.3",
    "react-native-toast-message": "^2.2.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.2.10",
    "typescript": "^5.3.0"
  }
}
